# ─── Frontend (Vite) ───────────────────────────────────────────────────────────

# WebRTC / Socket.io signaling server URL for the Emergency Livestream feature.
# Set this in Vercel → Project Settings → Environment Variables
VITE_STREAM_SERVER_URL=https://your-backend-url.onrender.com


# ─── Backend (server/) ─────────────────────────────────────────────────────────

# Port the signaling server listens on (Render sets this automatically)
PORT=3001

# Optional: extra allowed CORS origin (e.g. a custom domain)
CLIENT_URL=https://nyayasaarthi.vercel.app

# Optional: OpenAI key (leave blank to use free demo mode)
OPENAI_API_KEY=
