# NyayaSaarthi Frontend Environment

# Backend API base URL — used by chatbot to reach the Render backend
# Local dev: points to local backend server
VITE_API_BASE_URL=http://localhost:3001

# Signaling server for Emergency Livestream (Socket.io / WebRTC)
VITE_STREAM_SERVER_URL=http://localhost:3001

# Production on Vercel — set these in Vercel dashboard (NOT here):
# VITE_API_BASE_URL=https://nyayabot-backend.onrender.com
# VITE_STREAM_SERVER_URL=https://nyayabot-backend.onrender.com